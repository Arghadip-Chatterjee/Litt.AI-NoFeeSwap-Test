# NoFeeSwap Sandwich Bot — Environment Variables
# Copy this file to .env and fill in your values

# Private key of the bot's wallet (Hardhat account[2] by default)
BOT_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Hardhat node RPC endpoint (HTTP for sends, WS for mempool monitoring)
RPC_URL=http://127.0.0.1:8545
WS_URL=ws://127.0.0.1:8545

# Minimum profit required to attempt a sandwich (ETH)
MIN_PROFIT_ETH=0.0001
